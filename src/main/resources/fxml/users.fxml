<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" styleClass="root" style="-fx-background-color: #ECF0F1;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacie.controllers.UserController">
    <content>
        <VBox spacing="20" style="-fx-background-color: transparent;">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Sécurité &amp; Accès" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
    
    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
        <!-- ONGLET 1 : PROFILS -->
        <Tab text="Profils &amp; Habilitations">
            <HBox spacing="25" style="-fx-padding: 30;">
                <!-- LEFT CARD: Formulaire -->
                <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);" minWidth="350">
                    <Label text="Créer/Modifier un Profil" style="-fx-font-weight: 800; -fx-font-size: 18px; -fx-text-fill: #0F172A;"/>
                    <Separator/>
                    
                    <VBox spacing="6">
                        <Label text="Nom du profil *" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtProfilNom" promptText="Ex: Docteur, Vendeur..."/>
                    </VBox>
                    
                    <VBox spacing="6">
                        <Label text="Description" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtProfilDesc" />
                    </VBox>
                    
                    <VBox spacing="12" style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 15; -fx-margin-top: 10;">
                        <Label text="Autorisations (Cochez pour activer)" style="-fx-font-weight: 700; -fx-text-fill: #334155; -fx-font-size: 14px;"/>
                        <Separator/>
                        <CheckBox fx:id="chkDashboard" text="Accès Tableau de Bord (Finances)" style="-fx-text-fill: #475569;"/>
                        <CheckBox fx:id="chkVentes" text="Accès Ventes &amp; Caisse" style="-fx-text-fill: #475569;"/>
                        <CheckBox fx:id="chkStock" text="Accès Produits &amp; Démarque Inconnue" style="-fx-text-fill: #475569;"/>
                        <CheckBox fx:id="chkAchats" text="Accès Approvisionnement" style="-fx-text-fill: #475569;"/>
                        <CheckBox fx:id="chkFournisseurs" text="Accès Fournisseurs" style="-fx-text-fill: #475569;"/>
                        <CheckBox fx:id="chkRapports" text="Accès Rapports &amp; Exports" style="-fx-text-fill: #475569;"/>
                        <CheckBox fx:id="chkParametres" text="Accès Paramètres (Ce Menu)" style="-fx-text-fill: #475569;"/>
                    </VBox>
                    
                    <Region VBox.vgrow="ALWAYS"/>
                    <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                        <Button text="Réinitialiser" onAction="#resetProfilForm" styleClass="pos-btn" style="-fx-background-color: transparent; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-text-fill: #64748B; -fx-font-size: 14px; -fx-padding: 8 15;">
                            <graphic><Region styleClass="icon icon-refresh icon-dark"/></graphic>
                        </Button>
                        <Button text="Enregistrer" fx:id="btnSaveProfil" onAction="#saveProfil" styleClass="button-primary" style="-fx-font-size: 14px; -fx-padding: 8 20;">
                            <graphic><Region styleClass="icon icon-save" style="-fx-background-color: white;"/></graphic>
                        </Button>
                    </HBox>
                </VBox>
                
                <!-- RIGHT CARD: Tableau -->
                <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);">
                    <HBox alignment="CENTER_LEFT">
                        <VBox>
                            <Label text="Liste des Profils d'accès" style="-fx-font-weight: 800; -fx-font-size: 18px; -fx-text-fill: #0F172A;"/>
                            <Label text="Sélectionnez un profil pour modifier ses habilitations" style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Supprimer" onAction="#deleteProfil" styleClass="pos-btn" style="-fx-background-color: #FEF2F2; -fx-border-color: #FECACA; -fx-text-fill: #DC2626; -fx-border-radius: 6; -fx-font-weight: bold; -fx-padding: 8 15;">
                            <graphic><Region styleClass="icon icon-x" style="-fx-background-color: #DC2626;"/></graphic>
                        </Button>
                    </HBox>
                    <TableView fx:id="tableProfils" VBox.vgrow="ALWAYS" style="-fx-border-color: #E2E8F0; -fx-background-radius: 6; -fx-border-radius: 6;">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colProfilNom" text="Titre du Profil" prefWidth="200"/>
                            <TableColumn fx:id="colProfilDesc" text="Description" prefWidth="300"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>
        </Tab>
        
        <!-- ONGLET 2 : UTILISATEURS -->
        <Tab text="Comptes Utilisateurs">
            <HBox spacing="25" style="-fx-padding: 30;">
                <!-- CARD FORMULAIRE -->
                <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);" minWidth="320">
                    <Label text="Informations de l'Employé" style="-fx-font-weight: 800; -fx-font-size: 18px; -fx-text-fill: #0F172A;"/>
                    <Separator/>

                    <VBox spacing="6">
                        <Label text="Nom complet *" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtNom" promptText="Sera imprimé sur les factures"/>
                    </VBox>

                    <HBox spacing="12">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Identifiant Connexion *" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                            <TextField fx:id="txtIdentifiant" promptText="Sans espace"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Email" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                            <TextField fx:id="txtEmail"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="6">
                        <Label text="Mot de passe *" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                        <PasswordField fx:id="txtMotDePasse" promptText="Laisser vide si pas de changement"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Profil d'accès *" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="cmbProfil" promptText="Sélectionner le Rôle" maxWidth="Infinity"/>
                    </VBox>

                    <Label fx:id="lblErrorText" styleClass="error-label" visible="false"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 5 0 0 0;">
                        <Button text="Nouveau" onAction="#handleReset" styleClass="btn-outline"/>
                        <Button fx:id="btnSaveUser" text="Enregistrer l'Agent" onAction="#handleSave" styleClass="button-primary" style="-fx-padding: 8 20;"/>
                    </HBox>
                </VBox>

                <!-- CARD LISTE -->
                <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);">
                    <HBox alignment="CENTER_LEFT">
                        <VBox>
                            <Label text="Liste des Agents (Comptes)" style="-fx-font-weight: 800; -fx-font-size: 18px; -fx-text-fill: #0F172A;"/>
                            <Label text="Sélectionnez un agent pour modifier ses informations" style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Supprimer" onAction="#handleDelete" styleClass="btn-danger"/>
                    </HBox>
                    <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS" style="-fx-border-color: #E2E8F0; -fx-background-radius: 6; -fx-border-radius: 6;">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colNom" text="Identité" prefWidth="200"/>
                            <TableColumn fx:id="colIdentifiant" text="Login" prefWidth="150"/>
                            <TableColumn fx:id="colEmail" text="Email" prefWidth="150"/>
                            <TableColumn fx:id="colRole" text="Profil Assigné" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>
        </Tab>
        <!-- ONGLET 3 : INFOS PHARMACIE -->
        <Tab text="Paramètres de l'Établissement">
            <VBox alignment="CENTER" style="-fx-padding: 40;">
                <VBox spacing="25" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);" maxWidth="650" alignment="TOP_CENTER">
                    <Label text="Configuration de l'Établissement" style="-fx-font-weight: 900; -fx-font-size: 20px; -fx-text-fill: #0F172A;"/>
                    <Separator/>
                    
                    <GridPane hgap="20" vgap="20">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50" />
                            <ColumnConstraints percentWidth="50" />
                        </columnConstraints>
                        <!-- Row 0 -->
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Nom de la structure" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                            <TextField fx:id="txtInfoNom" promptText="Ex: PHARMACIE DU CENTRE" />
                        </VBox>
                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Téléphone" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                            <TextField fx:id="txtInfoPhone" promptText="Ex: +226 77 000 00 00" />
                        </VBox>
                        <!-- Row 1 -->
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Adresse complète" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                            <TextField fx:id="txtInfoAdresse" promptText="Ex: Quartier, Ville" />
                        </VBox>
                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Email / Infos légales (N.I.N.E.A)" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                            <TextField fx:id="txtInfoEmail" promptText="Email ou N.I.N.E.A" />
                        </VBox>
                        <!-- Row 2 (Spans 2 columns) -->
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                            <Label text="Message de fin de ticket (Pied de Ticket)" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                            <TextArea fx:id="txtInfoMessage" promptText="Merci de votre visite..." prefHeight="70" wrapText="true" />
                        </VBox>
                    </GridPane>
                    
                    <Label fx:id="lblInfoMsg" style="-fx-text-fill: #10B981; -fx-font-weight: bold; -fx-font-size: 14px;" visible="false"/>
                    
                    <HBox alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                        <Button text="Enregistrer les Modifications" onAction="#savePharmacieInfo" styleClass="button-primary" style="-fx-font-size: 16px; -fx-padding: 12 30;">
                            <graphic>
                                <Region styleClass="icon icon-save" style="-fx-background-color: white;"/>
                            </graphic>
                        </Button>
                    </HBox>
                </VBox>
            </VBox>
        </Tab>
        <!-- ONGLET 4 : SAUVEGARDE DB -->
        <Tab text="Sauvegarde &amp; Données">
            <VBox alignment="CENTER" style="-fx-padding: 40;">
                <VBox spacing="25" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);" maxWidth="650" alignment="TOP_CENTER">
                    <Label text="Sauvegarde de Sécurité" style="-fx-font-weight: 900; -fx-font-size: 20px; -fx-text-fill: #0F172A;"/>
                    <Separator/>
                    <VBox spacing="10" style="-fx-background-color: #FEF3C7; -fx-border-color: #F59E0B; -fx-border-width: 0 0 0 4; -fx-padding: 15; -fx-background-radius: 4;">
                        <Label text="Il est impératif de sauvegarder régulièrement l'intégralité de vos données (Clients, Ventes, Stock) sur un support externe (clé USB, disque dur)." wrapText="true" style="-fx-text-fill: #92400E; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                        <Label text="En cas de panne matérielle, ce fichier .sql permettra à votre support technique de restaurer l'intégralité du système." wrapText="true" style="-fx-text-fill: #B45309; -fx-font-style: italic; -fx-font-size: 13px;"/>
                    </VBox>
                    <HBox alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                        <Button text="Exporter la Base de Données (.sql)" onAction="#handleBackupDB" styleClass="button-primary" style="-fx-font-size: 16px; -fx-padding: 12 30;">
                            <graphic>
                                <Region styleClass="icon icon-database" style="-fx-background-color: white;"/>
                            </graphic>
                        </Button>
                    </HBox>
                </VBox>
            </VBox>
        </Tab>
        </TabPane>
        </VBox>
    </content>
</ScrollPane>

