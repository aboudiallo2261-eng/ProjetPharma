<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent;" styleClass="root" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacie.controllers.FournisseurController">
    <VBox spacing="20">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Gestion des Fournisseurs" styleClass="page-title"/>

    <HBox spacing="25" VBox.vgrow="ALWAYS">
        <!-- CARD FORMULAIRE -->
        <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);" minWidth="320">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox>
                    <Label text="Ajouter / Modifier" style="-fx-font-weight: 800; -fx-font-size: 17px; -fx-text-fill: #0F172A;"/>
                    <Label text="Sélectionnez une ligne pour modifier" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>
            <Separator/>

            <VBox spacing="6">
                <Label text="Nom de l'entreprise *" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                <TextField fx:id="txtNom" promptText="Obligatoire"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Personne de contact" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                <TextField fx:id="txtContact" promptText="Nom du représentant"/>
            </VBox>

            <HBox spacing="12">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Téléphone" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                    <TextField fx:id="txtTelephone"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Email" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                    <TextField fx:id="txtEmail"/>
                </VBox>
            </HBox>

            <VBox spacing="6">
                <Label text="Adresse" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                <TextField fx:id="txtAdresse"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Conditions de paiement" style="-fx-text-fill: #475569; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                <TextArea fx:id="txtConditions" prefRowCount="3" wrapText="true" promptText="Ex: 30 jours net, remise 5%..."/>
            </VBox>

            <Label fx:id="lblErrorText" styleClass="error-label" visible="false"/>

            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 5 0 0 0;">
                <Button text="Réinitialiser" onAction="#handleReset" styleClass="btn-outline"/>
                <Button fx:id="btnSave" text="Enregistrer" onAction="#handleSave" styleClass="button-primary" style="-fx-padding: 8 20;"/>
            </HBox>
        </VBox>

        <!-- CARD LISTE -->
        <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);">
            <HBox alignment="CENTER_LEFT">
                <VBox>
                    <Label text="Liste des Fournisseurs" style="-fx-font-weight: 800; -fx-font-size: 17px; -fx-text-fill: #0F172A;"/>
                    <Label text="Cliquez sur une ligne pour modifier" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Supprimer" onAction="#handleDelete" styleClass="btn-danger"/>
            </HBox>
            <Separator/>
            <TableView fx:id="tableFournisseurs" VBox.vgrow="ALWAYS" style="-fx-border-color: #E2E8F0; -fx-background-radius: 6; -fx-border-radius: 6;">
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNom" text="Entreprise" prefWidth="180"/>
                    <TableColumn fx:id="colContact" text="Contact" prefWidth="130"/>
                    <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="120"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>
    </VBox>
</ScrollPane>
