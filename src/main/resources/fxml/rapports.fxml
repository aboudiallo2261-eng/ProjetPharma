<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" styleClass="root" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacie.controllers.ReportController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Journal des Ventes &amp; Audits" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
    
    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
        <Tab text="Journal Détaillé des Ventes">
            <VBox spacing="15" style="-fx-padding: 15 0 0 0;">
                
                <!-- Barre de filtre - classes CSS sémantiques -->
                <GridPane hgap="15" vgap="12" styleClass="filter-card" VBox.vgrow="NEVER">
                    <columnConstraints>
                        <ColumnConstraints minWidth="65" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="280" />
                        <ColumnConstraints minWidth="65" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="160" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints minWidth="140" halignment="RIGHT"/>
                    </columnConstraints>
                    
                    <Label text="Période :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <DatePicker fx:id="dpDateDebut" promptText="Début" prefWidth="130"/>
                        <Label text="au" styleClass="filter-label"/>
                        <DatePicker fx:id="dpDateFin" promptText="Fin" prefWidth="130"/>
                    </HBox>

                    <Label text="Caissier :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cmbCaissier" promptText="Tous les Caissiers" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="0" onAction="#genererRapport"/>

                    <Button text="🔍 Filtrer" onAction="#genererRapport" styleClass="btn-filter"
                            GridPane.columnIndex="5" GridPane.rowIndex="0"/>
                    
                    <Label text="Catég. :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cmbCategorie" promptText="Toutes les Catégories" maxWidth="Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#genererRapport"/>

                    <Label text="Espèce :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cmbEspece" promptText="Toutes les Espèces" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="1" onAction="#genererRapport"/>
                    
                    <Button text="🔄 Réinitialiser" onAction="#resetRapportVente" styleClass="btn-outline-reset"
                            GridPane.columnIndex="5" GridPane.rowIndex="1"/>
                </GridPane>

                <!-- Tableau Ventes - Phase 3+4+5 -->
                <VBox spacing="10" VBox.vgrow="ALWAYS" styleClass="table-card">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <Label text="Total :" style="-fx-font-weight: bold;"/>
                        <Label fx:id="lblTotalFiltre" text="0 FCFA" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <!-- Phase 5 : Boutons PDF/CSV actifs uniquement si données présentes (géré par ReportController) -->
                        <Button fx:id="btnExportPdfVentes" text="📄 Exporter PDF" onAction="#exporterVentesPDF" styleClass="btn-action-red" disable="true"/>
                        <Button fx:id="btnExportCsvVentes" text="📊 Exporter CSV" onAction="#exporterCSV" styleClass="btn-action-green" disable="true"/>
                    </HBox>

                    <!-- Journal détaillé des ventes - CONSTRAINED via ReportController -->
                    <TableView fx:id="tableLignesVente" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <placeholder>
                            <Label text="📄 Aucune vente ne correspond à vos critères de filtre." styleClass="table-placeholder-label"/>
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="colLvDate" text="Date Vente" prefWidth="130"/>
                            <TableColumn fx:id="colLvTicket" text="Ticket N°" prefWidth="80"/>
                            <TableColumn fx:id="colLvAgent" text="Caissier" prefWidth="110"/>
                            <TableColumn fx:id="colLvProduit" text="Produit" prefWidth="180"/>
                            <TableColumn fx:id="colLvCat" text="Catégorie" prefWidth="110"/>
                            <TableColumn fx:id="colLvEsp" text="Espèce" prefWidth="90"/>
                            <TableColumn fx:id="colLvQte" text="Qté" prefWidth="60" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colLvPrix" text="Prix U." prefWidth="110" style="-fx-alignment: CENTER-RIGHT; -fx-padding: 0 10 0 0;"/>
                            <TableColumn fx:id="colLvTotal" text="Total" prefWidth="130" style="-fx-alignment: CENTER-RIGHT; -fx-padding: 0 10 0 0;"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
        </Tab>

        <Tab text="Audit des Stocks (Livre de bord)">
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-margin: 10 0 0 0; -fx-background-radius: 8;">
                <!-- Barre de filtre Audit -->
                <GridPane hgap="15" vgap="12" styleClass="filter-card" VBox.vgrow="NEVER">
                    <columnConstraints>
                        <ColumnConstraints minWidth="65" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="280" />
                        <ColumnConstraints minWidth="65" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="160" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints minWidth="140" halignment="RIGHT"/>
                    </columnConstraints>
                    
                    <Label text="Période :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <DatePicker fx:id="dpAuditDebut" promptText="Début" prefWidth="130"/>
                        <Label text="au" styleClass="filter-label"/>
                        <DatePicker fx:id="dpAuditFin" promptText="Fin" prefWidth="130"/>
                    </HBox>

                    <Label text="Agent :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cmbAuditUser" promptText="Tous les agents" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="0" onAction="#genererAudit"/>

                    <Button text="🔍 Filtrer" onAction="#genererAudit" styleClass="btn-filter"
                            GridPane.columnIndex="5" GridPane.rowIndex="0"/>

                    <Label text="Produit :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cmbAuditProduit" promptText="Tous les produits" maxWidth="Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#genererAudit"/>

                    <Label text="Mouv. :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cmbAuditType" promptText="Tous les mouvements" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="1" onAction="#genererAudit"/>

                    <Button text="🔄 Réinitialiser" onAction="#resetAudit" styleClass="btn-outline-reset"
                            GridPane.columnIndex="5" GridPane.rowIndex="1"/>
                </GridPane>
                <!-- Tableau Audit - CONSTRAINED via ReportController -->
                <TableView fx:id="tableAudit" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <placeholder>
                        <Label text="📕 Aucun mouvement de stock pour cette période." styleClass="table-placeholder-label"/>
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colAuditDate" text="Date &amp; Heure" prefWidth="150"/>
                        <TableColumn fx:id="colAuditType" text="Type Mouvement" prefWidth="140"/>
                        <TableColumn fx:id="colAuditRapport" text="Produit &amp; Lot" prefWidth="170"/>
                        <TableColumn fx:id="colAuditQte" text="Quantité" prefWidth="150" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colAuditRef" text="Référence" prefWidth="150"/>
                        <TableColumn fx:id="colAuditUser" text="Agent" prefWidth="110"/>
                    </columns>
                </TableView>
                <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 4 0 0 0;">
                    <!-- Phase 5 : Export PDF Audit -->
                    <Button fx:id="btnExportPdfAudit" text="📄 Exporter PDF" onAction="#exporterAuditPDF"
                            styleClass="btn-action-red" disable="true"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="Historique des Ajustements">
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-margin: 10 0 0 0; -fx-background-radius: 8;">
                <!-- Barre de filtre Ajustements -->
                <GridPane hgap="15" vgap="12" styleClass="filter-card" VBox.vgrow="NEVER">
                    <columnConstraints>
                        <ColumnConstraints minWidth="65" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="280" />
                        <ColumnConstraints minWidth="80" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="160" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="130"/>
                        <ColumnConstraints minWidth="140" halignment="RIGHT"/>
                    </columnConstraints>

                    <Label text="Période :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <DatePicker fx:id="dpAjustDebut" promptText="Début" prefWidth="130"/>
                        <Label text="au" styleClass="filter-label"/>
                        <DatePicker fx:id="dpAjustFin" promptText="Fin" prefWidth="130"/>
                    </HBox>

                    <Label text="Agent :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cmbAjustUser" promptText="Tous les agents" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="0" onAction="#genererAjustements"/>

                    <Button text="🔍 Filtrer" onAction="#genererAjustements" styleClass="btn-filter"
                            GridPane.columnIndex="5" GridPane.rowIndex="0" minWidth="-Infinity"/>

                    <Label text="Produit :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cmbAjustProduit" promptText="Tous les produits" maxWidth="Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#genererAjustements"/>

                    <Label text="Opération :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cmbAjustType" promptText="Toutes les opérations" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="1" onAction="#genererAjustements"/>

                    <!-- Phase 5 : Bouton PDF Ajustements - activé dynamiquement par ReportController -->
                    <HBox spacing="10" alignment="CENTER_RIGHT" GridPane.columnIndex="4" GridPane.rowIndex="1" GridPane.columnSpan="1">
                        <Button fx:id="btnExportPdfAjust" text="📄 Exporter PDF" onAction="#exporterAjustementsPDF"
                                styleClass="btn-action-red" disable="true" minWidth="-Infinity"/>
                    </HBox>

                    <Button text="🔄 Réinitialiser" onAction="#resetAjustements" styleClass="btn-outline-reset"
                            GridPane.columnIndex="5" GridPane.rowIndex="1" minWidth="-Infinity"/>
                </GridPane>
                <!-- Tableau Ajustements - CONSTRAINED via ReportController -->
                <TableView fx:id="tableAjustements" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <placeholder>
                        <Label text="⚙️ Aucun ajustement ou perte enregistré(e) pour cette période." styleClass="table-placeholder-label"/>
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colAdjDate" text="Date" prefWidth="120"/>
                        <TableColumn fx:id="colAdjProduit" text="Produit" prefWidth="140"/>
                        <TableColumn fx:id="colAdjLot" text="N° Lot" prefWidth="100"/>
                        <TableColumn fx:id="colAdjUser" text="Agent" prefWidth="110"/>
                        <TableColumn fx:id="colAdjMotif" text="Motif" prefWidth="130"/>
                        <TableColumn fx:id="colAdjQte" text="Qté" prefWidth="65"/>
                        <TableColumn fx:id="colAdjObs" text="Observation" prefWidth="200"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <Tab text="Registre des Clôtures (Z)">
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-margin: 10 0 0 0; -fx-background-radius: 8;">
                <!-- Barre de filtre Clôtures -->
                <GridPane hgap="15" vgap="12" styleClass="filter-card" VBox.vgrow="NEVER">
                    <columnConstraints>
                        <ColumnConstraints minWidth="65" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="280" />
                        <ColumnConstraints minWidth="65" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="160" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints minWidth="260" halignment="RIGHT"/>
                    </columnConstraints>

                    <Label text="Période :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <DatePicker fx:id="dpClotureDebut" promptText="Début" prefWidth="130"/>
                        <Label text="au" styleClass="filter-label"/>
                        <DatePicker fx:id="dpClotureFin" promptText="Fin" prefWidth="130"/>
                    </HBox>

                    <Label text="Agent :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cmbClotureUser" promptText="Tous les agents" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="0" onAction="#genererClotures"/>

                    <HBox spacing="10" alignment="CENTER_RIGHT" GridPane.columnIndex="5" GridPane.rowIndex="0">
                        <Button text="🔄 Réinitialiser" onAction="#resetClotures" styleClass="btn-outline-reset"/>
                        <Button text="🔍 Filtrer" onAction="#genererClotures" styleClass="btn-filter"/>
                    </HBox>
                </GridPane>
                
                <!-- Tableau Clôtures - CONSTRAINED via ReportController -->
                <TableView fx:id="tableClotures" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <placeholder>
                        <Label text="🔐 Aucune session de caisse pour cette période." styleClass="table-placeholder-label"/>
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colZDate" text="Date Clôture" prefWidth="175"/>
                        <TableColumn fx:id="colZAgent" text="Agent" prefWidth="100"/>
                        <TableColumn fx:id="colZStatut" text="Statut" prefWidth="90"/>
                        <TableColumn fx:id="colZTheorieEsp" text="Attendu (Espèces)" prefWidth="175" style="-fx-alignment: CENTER-RIGHT; -fx-padding: 0 10 0 0;"/>
                        <TableColumn fx:id="colZEcartEsp" text="Écart Esp." prefWidth="135"/>
                        <TableColumn fx:id="colZTheorieMob" text="Attendu (Mobile)" prefWidth="150" style="-fx-alignment: CENTER-RIGHT; -fx-padding: 0 10 0 0;"/>
                        <TableColumn fx:id="colZEcartMob" text="Écart Mobile" prefWidth="135"/>
                    </columns>
                </TableView>
                <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 4 0 0 0;">
                    <!-- Phase 5 : Export PDF clôtures -->
                    <Button fx:id="btnExportPdfCloture" text="📄 Exporter PDF" onAction="#exporterCloturesPDF"
                            styleClass="btn-action-red" disable="true"/>
                </HBox>
            </VBox>
        </Tab>
    </TabPane>
</VBox>

