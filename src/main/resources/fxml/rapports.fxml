<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<VBox spacing="20" styleClass="root" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacie.controllers.ReportController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Journal des Ventes &amp; Audits" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
    
    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
        <Tab text="Journal Détaillé des Ventes">
            <VBox spacing="15" style="-fx-padding: 15 0 0 0;">
                
                <!-- Barre de filtre - classes CSS sémantiques -->
                <GridPane hgap="15" vgap="12" styleClass="filter-card" VBox.vgrow="NEVER">
                    <columnConstraints>
                        <ColumnConstraints minWidth="65" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="280" />
                        <ColumnConstraints minWidth="65" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="160" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints minWidth="140" halignment="RIGHT"/>
                    </columnConstraints>
                    
                    <!-- Ligne 1 -->
                    <Label text="Période :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <DatePicker fx:id="dpDateDebut" promptText="Début" prefWidth="130"/>
                        <Label text="au" styleClass="filter-label"/>
                        <DatePicker fx:id="dpDateFin" promptText="Fin" prefWidth="130"/>
                    </HBox>

                    <Label text="Caissier :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cmbCaissier" promptText="Tous les Caissiers" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="0" onAction="#genererRapport"/>

                    <Button text="Filtrer" onAction="#genererRapport" styleClass="btn-filter"
                            GridPane.columnIndex="5" GridPane.rowIndex="0">
                        <graphic>
                            <SVGPath content="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" styleClass="btn-icon-white"/>
                        </graphic>
                    </Button>

                    <!-- Spinner de chargement asynchrone : visible uniquement pendant le Task -->
                    <ProgressIndicator fx:id="progressRapport" visible="false" managed="false"
                                       maxHeight="28" maxWidth="28"
                                       GridPane.columnIndex="4" GridPane.rowIndex="0"
                                       GridPane.rowSpan="2" GridPane.halignment="CENTER"
                                       GridPane.valignment="CENTER"/>
                    
                    <!-- Ligne 2 -->
                    <Label text="Catég. :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cmbCategorie" promptText="Toutes les Catégories" maxWidth="Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#genererRapport"/>

                    <Label text="Espèce :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cmbEspece" promptText="Toutes les Espèces" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="1" onAction="#genererRapport"/>
                    
                    <!-- Ligne 3 pour le Produit -->
                    <Label text="Produit :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="cmbRapportProduit" promptText="Tous les Produits" maxWidth="Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="2" onAction="#genererRapport"/>

                    <Button text="Réinitialiser" onAction="#resetRapportVente" styleClass="btn-outline-reset"
                            GridPane.columnIndex="5" GridPane.rowIndex="2">
                        <graphic>
                            <SVGPath content="M1 4v6h6 M23 20v-6h-6 M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15" styleClass="btn-icon-gray"/>
                        </graphic>
                    </Button>
                </GridPane>

                <!-- Tableau Ventes - Phase 3+4+5 -->
                <VBox spacing="10" VBox.vgrow="ALWAYS" styleClass="table-card">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <Label text="Total :" style="-fx-font-weight: bold;"/>
                        <Label fx:id="lblTotalFiltre" text="0 FCFA" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <!-- Phase 5 : Boutons PDF/CSV actifs uniquement si données présentes (géré par ReportController) -->
                        <Button fx:id="btnExportPdfVentes" text="Exporter PDF" onAction="#exporterVentesPDF"
                                styleClass="btn-action-red" disable="true" style="-fx-graphic-text-gap: 8;">
                            <graphic>
                                <javafx.scene.shape.SVGPath content="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" fill="WHITE"/>
                            </graphic>
                        </Button>
                        <Button fx:id="btnExportCsvVentes" text="Exporter Excel" onAction="#exporterCSV"
                                styleClass="btn-action-green" disable="true" style="-fx-graphic-text-gap: 8;">
                            <graphic>
                                <javafx.scene.shape.SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" fill="WHITE"/>
                            </graphic>
                        </Button>
                    </HBox>

                    <!-- Journal détaillé des ventes -->
                    <TableView fx:id="tableLignesVente" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <placeholder>
                            <Label text="📄 Aucune vente ne correspond à vos critères de filtre." styleClass="table-placeholder-label"/>
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="colLvDate" text="Date Vente" prefWidth="160" minWidth="150"/>
                            <TableColumn fx:id="colLvTicket" text="Ticket N°" prefWidth="180" minWidth="160"/>
                            <TableColumn fx:id="colLvAgent" text="Caissier" prefWidth="150" minWidth="130"/>
                            <TableColumn fx:id="colLvProduit" text="Produit" prefWidth="250" minWidth="200"/>
                            <TableColumn fx:id="colLvCat" text="Catégorie" prefWidth="120" minWidth="100"/>
                            <TableColumn fx:id="colLvEsp" text="Espèce" prefWidth="100" minWidth="90"/>
                            <TableColumn fx:id="colLvQte" text="Qté" prefWidth="80" minWidth="60" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colLvPrix" text="Prix U." prefWidth="150" minWidth="120" style="-fx-alignment: CENTER-RIGHT; -fx-padding: 0 10 0 0;"/>
                            <TableColumn fx:id="colLvTotal" text="Total" prefWidth="150" minWidth="120" style="-fx-alignment: CENTER-RIGHT; -fx-padding: 0 10 0 0;"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
        </Tab>

        <Tab text="Audit des Stocks (Livre de bord)">
            <VBox spacing="15" style="-fx-padding: 15 0 0 0;">

                <!-- Barre de filtre Audit -->
                <GridPane hgap="15" vgap="12" styleClass="filter-card" VBox.vgrow="NEVER">
                    <columnConstraints>
                        <ColumnConstraints minWidth="65" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="280" />
                        <ColumnConstraints minWidth="65" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="160" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints minWidth="140" halignment="RIGHT"/>
                    </columnConstraints>
                    
                    <Label text="Période :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <DatePicker fx:id="dpAuditDebut" promptText="Début" prefWidth="130"/>
                        <Label text="au" styleClass="filter-label"/>
                        <DatePicker fx:id="dpAuditFin" promptText="Fin" prefWidth="130"/>
                    </HBox>

                    <Label text="Agent :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cmbAuditUser" promptText="Tous les agents" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="0" onAction="#genererAudit"/>

                    <Button text="Filtrer" onAction="#genererAudit" styleClass="btn-filter"
                            GridPane.columnIndex="5" GridPane.rowIndex="0">
                        <graphic>
                            <SVGPath content="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" styleClass="btn-icon-white"/>
                        </graphic>
                    </Button>

                    <Label text="Produit :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cmbAuditProduit" promptText="Tous les produits" maxWidth="Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#genererAudit"/>

                    <Label text="Mouv. :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cmbAuditType" promptText="Tous les mouvements" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="1" onAction="#genererAudit"/>

                    <Button text="Réinitialiser" onAction="#resetAudit" styleClass="btn-outline-reset"
                            GridPane.columnIndex="5" GridPane.rowIndex="1">
                        <graphic>
                            <SVGPath content="M1 4v6h6 M23 20v-6h-6 M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15" styleClass="btn-icon-gray"/>
                        </graphic>
                    </Button>
                </GridPane>

                <!-- Tableau Audit — même wrapper table-card que Journal des Ventes -->
                <VBox spacing="10" VBox.vgrow="ALWAYS" styleClass="table-card">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <Label text="Mouvements :" style="-fx-font-weight: bold;"/>
                        <Label fx:id="lblTotalAudit" text="0 mouvement(s)"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnExportPdfAudit" text="Exporter PDF" onAction="#exporterAuditPDF"
                                styleClass="btn-action-red" disable="true" style="-fx-graphic-text-gap: 8;">
                            <graphic>
                                <javafx.scene.shape.SVGPath content="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" fill="WHITE"/>
                            </graphic>
                        </Button>
                        <Button fx:id="btnExportExcelAudit" text="Exporter Excel" onAction="#exporterAuditExcel"
                                styleClass="btn-action-green" disable="true" style="-fx-graphic-text-gap: 8;">
                            <graphic>
                                <javafx.scene.shape.SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" fill="WHITE"/>
                            </graphic>
                        </Button>
                    </HBox>

                    <!-- Tableau Audit - Scrollable via minWidth -->
                    <TableView fx:id="tableAudit" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <placeholder>
                            <Label text="📕 Aucun mouvement de stock pour cette période." styleClass="table-placeholder-label"/>
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="colAuditDate" text="Date &amp; Heure" prefWidth="150" minWidth="130"/>
                            <TableColumn fx:id="colAuditType" text="Type Mouvement" prefWidth="140" minWidth="120"/>
                            <TableColumn fx:id="colAuditRapport" text="Produit &amp; Lot" prefWidth="200" minWidth="160"/>
                            <TableColumn fx:id="colAuditQte" text="Quantité" prefWidth="160" minWidth="140" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colAuditRef" text="Référence" prefWidth="210" minWidth="180"/>
                            <TableColumn fx:id="colAuditUser" text="Agent" prefWidth="120" minWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
        </Tab>

        <Tab text="Historique des Ajustements">
            <VBox spacing="15" style="-fx-padding: 15 0 0 0;">

                <!-- Barre de filtre Ajustements — même structure que Journal des Ventes -->
                <GridPane hgap="15" vgap="12" styleClass="filter-card" VBox.vgrow="NEVER">
                    <columnConstraints>
                        <ColumnConstraints minWidth="65" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="280" />
                        <ColumnConstraints minWidth="80" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="160" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints minWidth="140" halignment="RIGHT"/>
                    </columnConstraints>

                    <Label text="Période :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <DatePicker fx:id="dpAjustDebut" promptText="Début" prefWidth="130"/>
                        <Label text="au" styleClass="filter-label"/>
                        <DatePicker fx:id="dpAjustFin" promptText="Fin" prefWidth="130"/>
                    </HBox>

                    <Label text="Agent :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cmbAjustUser" promptText="Tous les agents" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="0" onAction="#genererAjustements"/>

                    <Button text="Filtrer" onAction="#genererAjustements" styleClass="btn-filter"
                            GridPane.columnIndex="5" GridPane.rowIndex="0">
                        <graphic>
                            <SVGPath content="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" styleClass="btn-icon-white"/>
                        </graphic>
                    </Button>

                    <!-- Spinner de chargement asynchrone -->
                    <ProgressIndicator fx:id="progressAjust" visible="false" managed="false"
                                       maxHeight="28" maxWidth="28"
                                       GridPane.columnIndex="4" GridPane.rowIndex="0"
                                       GridPane.rowSpan="2" GridPane.halignment="CENTER"
                                       GridPane.valignment="CENTER"/>

                    <Label text="Produit :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cmbAjustProduit" promptText="Tous les produits" maxWidth="Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#genererAjustements"/>

                    <Label text="Opération :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cmbAjustType" promptText="Toutes les opérations" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="1" onAction="#genererAjustements"/>

                    <Button text="Réinitialiser" onAction="#resetAjustements" styleClass="btn-outline-reset"
                            GridPane.columnIndex="5" GridPane.rowIndex="1">
                        <graphic>
                            <SVGPath content="M1 4v6h6 M23 20v-6h-6 M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15" styleClass="btn-icon-gray"/>
                        </graphic>
                    </Button>
                </GridPane>

                <!-- Tableau Ajustements — même wrapper table-card que Journal des Ventes -->
                <VBox spacing="10" VBox.vgrow="ALWAYS" styleClass="table-card">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <Label text="Résultats :" style="-fx-font-weight: bold;"/>
                        <Label fx:id="lblTotalAjustements" text="0 enregistrement(s)"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnExportPdfAjust" text="Exporter PDF" onAction="#exporterAjustementsPDF"
                                styleClass="btn-action-red" disable="true" style="-fx-graphic-text-gap: 8;">
                            <graphic>
                                <javafx.scene.shape.SVGPath content="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" fill="WHITE"/>
                            </graphic>
                        </Button>
                        <Button fx:id="btnExportExcelAjust" text="Exporter Excel" onAction="#exporterAjustementsExcel"
                                styleClass="btn-action-green" disable="true" style="-fx-graphic-text-gap: 8;">
                            <graphic>
                                <javafx.scene.shape.SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" fill="WHITE"/>
                            </graphic>
                        </Button>
                    </HBox>

                    <TableView fx:id="tableAjustements" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <placeholder>
                            <Label text="⚙️ Aucun ajustement ou perte enregistré(e) pour cette période." styleClass="table-placeholder-label"/>
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="colAdjDate" text="Date" prefWidth="140" minWidth="130"/>
                            <TableColumn fx:id="colAdjProduit" text="Produit" prefWidth="180" minWidth="160"/>
                            <TableColumn fx:id="colAdjLot" text="N° Lot" prefWidth="120" minWidth="100"/>
                            <TableColumn fx:id="colAdjUser" text="Agent" prefWidth="130" minWidth="110"/>
                            <TableColumn fx:id="colAdjMotif" text="Motif" prefWidth="210" minWidth="180"/>
                            <TableColumn fx:id="colAdjQte" text="Qté" prefWidth="80" minWidth="65" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colAdjObs" text="Observation" prefWidth="250" minWidth="220"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
        </Tab>


        <Tab text="Registre des Clôtures (Z)">
            <VBox spacing="15" style="-fx-padding: 15 0 0 0;">

                <!-- Barre de filtre Clôtures — même structure que Journal des Ventes -->
                <GridPane hgap="15" vgap="12" styleClass="filter-card" VBox.vgrow="NEVER">
                    <columnConstraints>
                        <ColumnConstraints minWidth="65" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="280" />
                        <ColumnConstraints minWidth="65" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="160" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints minWidth="140" halignment="RIGHT"/>
                    </columnConstraints>

                    <Label text="Période :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <DatePicker fx:id="dpClotureDebut" promptText="Début" prefWidth="130"/>
                        <Label text="au" styleClass="filter-label"/>
                        <DatePicker fx:id="dpClotureFin" promptText="Fin" prefWidth="130"/>
                    </HBox>

                    <Label text="Agent :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cmbClotureUser" promptText="Tous les agents" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="0" onAction="#genererClotures"/>

                    <!-- Filtrer en haut à droite — identique aux autres onglets -->
                    <Button text="Filtrer" onAction="#genererClotures" styleClass="btn-filter"
                            GridPane.columnIndex="5" GridPane.rowIndex="0">
                        <graphic>
                            <SVGPath content="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" styleClass="btn-icon-white"/>
                        </graphic>
                    </Button>

                    <!-- LIGNE 2 : Nouveaux filtres de clôture -->
                    <Label text="Statut :" styleClass="filter-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cmbClotureStatut" promptText="Tous les statuts" maxWidth="Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#genererClotures"/>
                              
                    <Label text="Bilan :" styleClass="filter-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cmbClotureBilan" promptText="Tous les bilans" maxWidth="Infinity"
                              GridPane.columnIndex="3" GridPane.rowIndex="1" onAction="#genererClotures"/>

                    <!-- Bouton Réinitialiser pour garder la symétrie -->
                    <Button text="Réinitialiser" onAction="#resetClotures" styleClass="btn-outline-reset"
                            GridPane.columnIndex="5" GridPane.rowIndex="1">
                        <graphic>
                            <SVGPath content="M1 4v6h6 M23 20v-6h-6 M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15" styleClass="btn-icon-gray"/>
                        </graphic>
                    </Button>
                </GridPane>

                <!-- Tableau Clôtures — même wrapper table-card que Journal des Ventes -->
                <VBox spacing="10" VBox.vgrow="ALWAYS" styleClass="table-card">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <Label text="Sessions :" style="-fx-font-weight: bold;"/>
                        <Label fx:id="lblTotalClotures" text="0 session(s)"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #8e44ad;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnExportPdfCloture" text="Exporter PDF" onAction="#exporterCloturesPDF"
                                styleClass="btn-action-red" disable="true" style="-fx-graphic-text-gap: 8;">
                            <graphic>
                                <javafx.scene.shape.SVGPath content="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" fill="WHITE"/>
                            </graphic>
                        </Button>
                        <Button fx:id="btnExportExcelCloture" text="Exporter Excel" onAction="#exporterCloturesExcel"
                                styleClass="btn-action-green" disable="true" style="-fx-graphic-text-gap: 8;">
                            <graphic>
                                <javafx.scene.shape.SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" fill="WHITE"/>
                            </graphic>
                        </Button>
                    </HBox>

                    <!-- Tableau Clôtures - Scrollable via minWidth -->
                    <TableView fx:id="tableClotures" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <placeholder>
                            <Label text="🔐 Aucune session de caisse pour cette période." styleClass="table-placeholder-label"/>
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="colZDate" text="Date Clôture" prefWidth="175" minWidth="160"/>
                            <TableColumn fx:id="colZAgent" text="Agent" prefWidth="130" minWidth="110"/>
                            <TableColumn fx:id="colZStatut" text="Statut" prefWidth="90" minWidth="80"/>
                            <TableColumn fx:id="colZTheorieEsp" text="Attendu (Espèces)" prefWidth="210" minWidth="190" style="-fx-alignment: CENTER-RIGHT; -fx-padding: 0 10 0 0;"/>
                            <TableColumn fx:id="colZEcartEsp" text="Écart Esp." prefWidth="135" minWidth="115"/>
                            <TableColumn fx:id="colZTheorieMob" text="Attendu (Mobile)" prefWidth="185" minWidth="165" style="-fx-alignment: CENTER-RIGHT; -fx-padding: 0 10 0 0;"/>
                            <TableColumn fx:id="colZEcartMob" text="Écart Mobile" prefWidth="135" minWidth="115"/>
                        </columns>
                    </TableView>
