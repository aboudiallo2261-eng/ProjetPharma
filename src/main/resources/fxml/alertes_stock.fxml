<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>

<VBox spacing="20" styleClass="modal-root" stylesheets="@../css/styles.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pharmacie.controllers.AlerteStockController">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- HEADER PREMIUM : Titre, Badges Compteurs et Actions         -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="20" styleClass="modal-header">
        <!-- Titre avec Icône -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <SVGPath content="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9 M13.73 21a2 2 0 0 1-3.46 0" styleClass="icon-bell"/>
            <Label text="Centre d'Alertes" styleClass="modal-title"/>
        </HBox>
        
        <Region HBox.hgrow="ALWAYS"/>
        
        <!-- Compteur : Ruptures (Style KPI Mini) -->
        <HBox styleClass="mini-stat-card">
            <StackPane styleClass="mini-icon-box-red">
                <SVGPath content="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z M12 9v4 M12 17h.01" styleClass="mini-icon-red"/>
            </StackPane>
            <VBox spacing="2" alignment="CENTER_LEFT">
                <Label text="Ruptures" styleClass="mini-stat-title"/>
                <Label fx:id="lblTotalAlertes" text="0" styleClass="mini-stat-value, text-red"/>
            </VBox>
        </HBox>
        
        <Separator orientation="VERTICAL" styleClass="header-separator"/>
        
        <!-- Compteur : Péremptions (Style KPI Mini) -->
        <HBox styleClass="mini-stat-card">
            <StackPane styleClass="mini-icon-box-purple">
                <SVGPath content="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" styleClass="mini-icon-purple"/> <!-- Alternative: Calendrier -->
            </StackPane>
            <VBox spacing="2" alignment="CENTER_LEFT">
                <Label text="Périmés / Proches" styleClass="mini-stat-title"/>
                <Label fx:id="lblTotalPerimes" text="0" styleClass="mini-stat-value, text-purple"/>
            </VBox>
        </HBox>
        
        <Separator orientation="VERTICAL" styleClass="header-separator"/>
        
        <!-- Action Primaire -->
        <Button text="Imprimer" onAction="#imprimerListe" styleClass="btn-action-green">
            <graphic>
                <SVGPath content="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z" styleClass="btn-icon-white"/>
            </graphic>
        </Button>
    </HBox>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- BARRE DE RECHERCHE & FILTRES FLUIDES                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <HBox spacing="15" alignment="CENTER_LEFT" styleClass="filter-card">
        <Label text="Filtrer :" styleClass="filter-label"/>
        <ComboBox fx:id="cmbFiltreCategorie" prefWidth="200" promptText="Toutes catégories" onAction="#filtrerAlertes"/>
        
        <Region HBox.hgrow="ALWAYS"/>
        
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="search-box">
            <SVGPath content="M11 19a8 8 0 100-16 8 8 0 000 16zM21 21l-4.35-4.35" styleClass="search-icon"/>
            <TextField fx:id="txtRecherche" promptText="Rechercher un produit..." styleClass="search-field" prefWidth="250"/>
        </HBox>
    </HBox>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- CONTENU PRINCIPAL : ONGLETS & TABLEAUX                      -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" styleClass="modern-tab-pane">

        <!-- ===== ONGLET 1 : RUPTURES ===== -->
        <Tab text="Ruptures &amp; Stocks Faibles">
            <VBox spacing="0" styleClass="tab-content-box">
                <HBox styleClass="tab-info-banner">
                    <SVGPath content="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z M13 2v7h7" styleClass="info-icon"/>
                    <Label text="Produits sous le seuil d'alerte. Double-cliquez sur une ligne pour préparer une commande." styleClass="info-text"/>
                </HBox>
                
                <TableView fx:id="tableAlertes" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <placeholder>
                        <VBox alignment="CENTER" spacing="10">
                            <SVGPath content="M22 11.08V12a10 10 0 1 1-5.93-9.14 M22 4L12 14.01l-3-3" styleClass="success-icon-large"/>
                            <Label text="Inventaire Sain !" styleClass="success-title"/>
                            <Label text="Aucun produit n'est actuellement en rupture de stock." styleClass="success-subtitle"/>
                        </VBox>
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colRef" text="Référence" prefWidth="90"/>
                        <TableColumn fx:id="colNom" text="Nom du Produit" prefWidth="280"/>
                        <TableColumn fx:id="colCategorie" text="Catégorie" prefWidth="180"/>
                        <TableColumn fx:id="colStockActuel" text="Stock Actuel" prefWidth="120" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold; -fx-text-fill: #E74C3C;"/>
                        <TableColumn fx:id="colSeuil" text="Seuil Alerte" prefWidth="120" style="-fx-alignment: CENTER-RIGHT;"/>
                        <TableColumn fx:id="colQteSuggerable" text="À Commander" prefWidth="140" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <!-- ===== ONGLET 2 : PÉREMPTIONS ===== -->
        <Tab text="Périmés &amp; Proches Expiration">
            <VBox spacing="0" styleClass="tab-content-box">
                <HBox styleClass="tab-info-banner">
                    <SVGPath content="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z M13 2v7h7" styleClass="info-icon"/>
                    <Label text="Lots périmés (en rouge) et lots expirant dans moins de 30 jours (en orange)." styleClass="info-text"/>
                </HBox>
                
                <TableView fx:id="tablePerimes" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <placeholder>
                        <VBox alignment="CENTER" spacing="10">
                            <SVGPath content="M22 11.08V12a10 10 0 1 1-5.93-9.14 M22 4L12 14.01l-3-3" styleClass="success-icon-large"/>
                            <Label text="Aucune urgence" styleClass="success-title"/>
                            <Label text="Tous les lots ont une date d'expiration rassurante (> 30 jours)." styleClass="success-subtitle"/>
                        </VBox>
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colPerimNom" text="Nom du Produit" prefWidth="260"/>
                        <TableColumn fx:id="colPerimLot" text="N° Lot" prefWidth="140"/>
                        <TableColumn fx:id="colPerimExp" text="Expiration" prefWidth="130" style="-fx-alignment: CENTER; -fx-font-weight: bold;"/>
                        <TableColumn fx:id="colPerimQte" text="Stock Restant" prefWidth="120" style="-fx-alignment: CENTER-RIGHT;"/>
                        <TableColumn fx:id="colPerimStatut" text="Statut" prefWidth="140" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colPerimJours" text="Jours Restants" prefWidth="130" style="-fx-alignment: CENTER; -fx-font-weight: bold;"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

    </TabPane>
</VBox>
