<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacie.controllers.AlerteStockController">
    
    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="⚠️ Alertes &amp; Approvisionnements" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #E74C3C;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🖨️ Imprimer la Liste d'Alerte" onAction="#imprimerListe"
                style="-fx-background-color: #34495E; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 8 20; -fx-background-radius: 6;"/>
    </HBox>

    <Label text="Consultez cette liste avant d'appeler vos grossistes. Les produits affichés ont franchi leur seuil d'alerte."
           style="-fx-font-size: 14px; -fx-text-fill: #7F8C8D;"/>

    <!-- CONTROLS & FILTERS -->
    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 3);">
        <Label text="🔍 Filtrer par Catégorie :" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="cmbFiltreCategorie" prefWidth="250" promptText="Toutes les catégories" onAction="#filtrerAlertes"/>
        
        <Label text="Nom du produit :" style="-fx-font-weight: bold; -fx-padding: 0 0 0 20;"/>
        <TextField fx:id="txtRecherche" promptText="Ex: Paracétamol..." prefWidth="250" />
        
        <Region HBox.hgrow="ALWAYS"/>
        
        <VBox alignment="CENTER_RIGHT">
            <Label text="Total en Alerte :" style="-fx-font-size: 13px; -fx-text-fill: #95A5A6;"/>
            <Label fx:id="lblTotalAlertes" text="0 Produit(s)" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #E74C3C;"/>
        </VBox>
    </HBox>

    <!-- DATA TABLE -->
    <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 3);">
        <TableView fx:id="tableAlertes" VBox.vgrow="ALWAYS" style="-fx-border-color: #BDC3C7; -fx-font-size: 14px;">
            <placeholder>
                <VBox alignment="CENTER" spacing="10">
                    <Label text="✅ Excellent ! Aucun produit n'est en rupture de stock." style="-fx-text-fill: #27AE60; -fx-font-size: 16px; -fx-font-weight: bold;" />
                    <Label text="Votre inventaire actuel est sain." style="-fx-text-fill: #95A5A6;" />
                </VBox>
            </placeholder>
            <columns>
                <TableColumn fx:id="colRef" text="Réf." prefWidth="100"/>
                <TableColumn fx:id="colNom" text="Nom du Produit" prefWidth="280"/>
                <TableColumn fx:id="colCategorie" text="Catégorie" prefWidth="180"/>
                <TableColumn fx:id="colStockActuel" text="Stock Actuel" prefWidth="120" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold; -fx-text-fill: #E74C3C;"/>
                <TableColumn fx:id="colSeuil" text="Seuil d'Alerte" prefWidth="120" style="-fx-alignment: CENTER-RIGHT;"/>
                <TableColumn fx:id="colQteSuggerable" text="Stock à Reconstituer" prefWidth="150" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold; -fx-text-fill: #3498DB;"/>
            </columns>
        </TableView>
    </VBox>
    
</VBox>

