<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<!-- Racine encapsulée dans un ScrollPane pour le défilement adaptatif -->
<ScrollPane fitToWidth="true" style="-fx-background: #F4F6F8; -fx-background-color: transparent;" hbarPolicy="NEVER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacie.controllers.AchatDetailsController">
    
    <!-- Conteneur principal original -->
    <VBox spacing="20" style="-fx-background-color: #F4F6F8; -fx-padding: 30;">

        <!-- 1. EN-TETE / HEADER ACTION -->
        <HBox alignment="CENTER" spacing="20">
            <VBox VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">
                <Label text="Détails de l'Achat" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Date d'enregistrement :" style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;"/>
                    <Label fx:id="lblAchatDate" style="-fx-text-fill: #34495e; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    <Label text="•" style="-fx-text-fill: #BDC3C7;"/>
                    <Label text="Validé" style="-fx-background-color: #E8F8F5; -fx-text-fill: #27AE60; -fx-font-weight: bold; -fx-padding: 2 8; -fx-background-radius: 10; -fx-font-size: 11px;"/>
                </HBox>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <Label fx:id="lblAchatId" visible="false" managed="false"/>
                <Button text="Fermer" onAction="#fermer" style="-fx-background-color: white; -fx-text-fill: #7f8c8d; -fx-border-color: #BDC3C7; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 20; -fx-font-size: 14px; -fx-cursor: hand;"/>
                <Button text="🖨️ Exporter PDF" onAction="#imprimerPdf" style="-fx-background-color: #007BFF; -fx-text-fill: white; -fx-font-weight: bold; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 20; -fx-font-size: 14px; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 123, 255, 0.3), 5, 0, 0, 3);"/>
            </HBox>
        </HBox>

        <!-- 2. CARTES D'INFORMATIONS -->
        <HBox spacing="20" alignment="TOP_CENTER">
            
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="🏥" style="-fx-font-size: 20px;"/>
                    <Label text="INFORMATIONS ETABLISSEMENT" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #95a5a6;"/>
                </HBox>
                <VBox spacing="2" style="-fx-padding: 5 0 0 25;">
                    <Label fx:id="lblPharmacieNom" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                    <Label fx:id="lblPharmacieContact" wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #555555;"/>
                </VBox>
            </VBox>

            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="📦" style="-fx-font-size: 20px;"/>
                    <Label text="FOURNISSEUR" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #95a5a6;"/>
                </HBox>
                <VBox spacing="2" style="-fx-padding: 5 0 0 25;">
                    <Label fx:id="lblFournisseurNom" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                    <Label fx:id="lblFournisseurContact" style="-fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <Label fx:id="lblFournisseurAdresse" style="-fx-font-size: 13px; -fx-text-fill: #555555;"/>
                </VBox>
            </VBox>
        </HBox>

        <!-- ZONE CENTRALE : Titre Commande + Facture -->
        <VBox alignment="CENTER" spacing="5" style="-fx-padding: 10 0 10 0;">
            <Label text="BON DE COMMANDE" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-letter-spacing: 2px;"/>
            <HBox alignment="CENTER" spacing="8">
                <Label text="Facture N°" style="-fx-font-size: 18px; -fx-text-fill: #34495E;"/>
                <Label fx:id="lblRefFacture" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #E67E22;"/>
            </HBox>
        </VBox>

        <!-- 3. TABLEAU DES PRODUITS : Hauteur allongée (ex: 450) puisque la page scroll ! -->
        <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
            <TableView fx:id="tableLignes" prefHeight="450" style="-fx-base: white; -fx-background-color: white; -fx-control-inner-background: white; -fx-text-fill: black;">
                <columns>
                    <TableColumn fx:id="colProduit" text="PRODUIT" prefWidth="250" style="-fx-alignment: CENTER-LEFT; -fx-font-size: 13px; -fx-text-fill: black;"/>
                    <TableColumn fx:id="colLot" text="N° LOT" prefWidth="120" style="-fx-alignment: CENTER-LEFT; -fx-font-size: 13px; -fx-text-fill: black;"/>
                    <TableColumn fx:id="colQte" text="QTE" prefWidth="80" style="-fx-alignment: CENTER; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: black;"/>
                    <TableColumn fx:id="colPrixU" text="PRIX UNT." prefWidth="120" style="-fx-alignment: CENTER-RIGHT; -fx-font-size: 13px; -fx-text-fill: black;"/>
                    <TableColumn fx:id="colTotal" text="SOUS-TOTAL" prefWidth="150" style="-fx-alignment: CENTER-RIGHT; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: black;"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- 4. TOTAL FOOTER BANNER -->
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
            <HBox alignment="CENTER" spacing="15" style="-fx-background-color: #007BFF; -fx-padding: 10 20; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0, 123, 255, 0.4), 8, 0, 0, 3);">
                <Label text="MONTANT TOTAL :" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-opacity: 0.9;"/>
                <Label fx:id="lblTotalCommande" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>
        </HBox>

    </VBox>
</ScrollPane>

