<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToWidth="true" styleClass="main-content-area" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacie.controllers.DashboardController">
    <VBox spacing="25" styleClass="root">
        <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
        </padding>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- HEADER & FILTRES FLUENT DESIGN                              -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <VBox spacing="20">
            <!-- TITRE -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="Tableau de Bord Analytique" styleClass="dashboard-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ProgressIndicator fx:id="progressIndicator" prefWidth="24" prefHeight="24" visible="false" managed="false"/>
            </HBox>
            
            <!-- Barre de filtre fluide (Remplacement du GridPane rigide) -->
            <HBox spacing="15" alignment="CENTER_LEFT" styleClass="filter-card">
                <Label text="Période :" styleClass="filter-label"/>
                <ComboBox fx:id="cmbPeriode" prefWidth="150" onAction="#onPeriodeChange"/>
                
                <Label text="De :" styleClass="filter-label" style="-fx-padding: 0 0 0 10;"/>
                <DatePicker fx:id="dpDebut" promptText="Début" prefWidth="130"/>
                <Label text="au" styleClass="filter-label"/>
                <DatePicker fx:id="dpFin" promptText="Fin" prefWidth="130"/>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <Button text="Réinitialiser" onAction="#reinitialiserPlage" styleClass="btn-outline-reset">
                    <graphic>
                        <SVGPath content="M1 4v6h6 M23 20v-6h-6 M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15" styleClass="btn-icon-gray"/>
                    </graphic>
                </Button>
                <Button text="Appliquer" onAction="#chargerDonnees" styleClass="btn-filter">
                    <graphic>
                        <SVGPath content="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" styleClass="btn-icon-white"/>
                    </graphic>
                </Button>
            </HBox>
        </VBox>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ROW 1 : KPI CARDS (CA, Bénéfice, Volume, Alertes)           -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <HBox spacing="12">
            <!-- CA -->
            <HBox HBox.hgrow="ALWAYS" styleClass="card, kpi-card">
                <VBox HBox.hgrow="ALWAYS" spacing="5">
                    <Label text="Chiffre d'Affaires" styleClass="kpi-title"/>
                    <Label fx:id="lblCA" text="— FCFA" styleClass="kpi-value, kpi-text-green"/>
                </VBox>
            </HBox>
            
            <!-- BÉNÉFICE -->
            <HBox HBox.hgrow="ALWAYS" styleClass="card, kpi-card">
                <VBox HBox.hgrow="ALWAYS" spacing="5">
                    <Label text="Bénéfice Net Estimé" styleClass="kpi-title"/>
                    <Label fx:id="lblBenefice" text="— FCFA" styleClass="kpi-value, kpi-text-blue"/>
                </VBox>
            </HBox>
            
            <!-- VOLUME -->
            <HBox HBox.hgrow="ALWAYS" styleClass="card, kpi-card">
                <VBox HBox.hgrow="ALWAYS" spacing="5">
                    <Label text="Volume de Ventes" styleClass="kpi-title"/>
                    <Label fx:id="lblVolume" text="—" styleClass="kpi-value, kpi-text-purple"/>
                </VBox>
            </HBox>
            
            <!-- ALERTES -->
            <HBox HBox.hgrow="ALWAYS" styleClass="card, kpi-card">
                <VBox HBox.hgrow="ALWAYS" spacing="5">
                    <Label text="Alertes Stock / Exp" styleClass="kpi-title"/>
                    <Label fx:id="lblAlertes" text="— / —" styleClass="kpi-value, kpi-text-red"/>
                </VBox>
            </HBox>
        </HBox>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ROW 2 : KPI CARDS (Valeur Stock, Espèces, Mobile Money)     -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <HBox spacing="12">
            <!-- VALEUR STOCK -->
            <HBox HBox.hgrow="ALWAYS" styleClass="card, kpi-card">
                <VBox HBox.hgrow="ALWAYS" spacing="5">
                    <Label text="Valeur Totale Stock" styleClass="kpi-title"/>
                    <Label fx:id="lblValeurStock" text="— FCFA" styleClass="kpi-value, kpi-text-teal"/>
                </VBox>
            </HBox>
            
            <!-- ESPÈCES -->
            <HBox HBox.hgrow="ALWAYS" styleClass="card, kpi-card">
                <VBox HBox.hgrow="ALWAYS" spacing="5">
                    <Label text="Recettes Espèces" styleClass="kpi-title"/>
                    <Label fx:id="lblEspeces" text="— FCFA" styleClass="kpi-value, kpi-text-orange"/>
                </VBox>
            </HBox>
            
            <!-- MOBILE MONEY -->
            <HBox HBox.hgrow="ALWAYS" styleClass="card, kpi-card">
                <VBox HBox.hgrow="ALWAYS" spacing="5">
                    <Label text="Recettes Mobile" styleClass="kpi-title"/>
                    <Label fx:id="lblMobile" text="— FCFA" styleClass="kpi-value, kpi-text-indigo"/>
                </VBox>
            </HBox>
        </HBox>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- CHARTS SECTION                                              -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <VBox spacing="20">
            <!-- EVOLUTION CA vs ACHATS -->
            <VBox styleClass="card, chart-box">
                <Label text="Évolution CA vs Coût des Achats" styleClass="section-title"/>
                <LineChart fx:id="chartEvolution" prefHeight="300" animated="true" styleClass="premium-chart">
                    <xAxis><CategoryAxis label="Période"/></xAxis>
                    <yAxis><NumberAxis label="Montant (FCFA)"/></yAxis>
                </LineChart>
            </VBox>

            <!-- CA PAR CATÉGORIE & ESPÈCE -->
            <HBox spacing="20">
                <VBox HBox.hgrow="ALWAYS" styleClass="card, chart-box">
                    <Label text="CA par Catégorie" styleClass="section-title"/>
                    <BarChart fx:id="barCategorie" prefHeight="260" animated="true" styleClass="premium-chart">
                        <xAxis><CategoryAxis label="Catégorie"/></xAxis>
                        <yAxis><NumberAxis label="CA (FCFA)"/></yAxis>
                    </BarChart>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" styleClass="card, chart-box">
                    <Label text="CA par Espèce" styleClass="section-title"/>
                    <BarChart fx:id="barEspece" prefHeight="260" animated="true" styleClass="premium-chart">
                        <xAxis><CategoryAxis label="Espèce"/></xAxis>
                        <yAxis><NumberAxis label="CA (FCFA)"/></yAxis>
                    </BarChart>
                </VBox>
            </HBox>

            <!-- TOP PRODUITS -->
            <HBox spacing="20">
                <VBox HBox.hgrow="ALWAYS" styleClass="card, chart-box">
                    <Label text="Top 10 Produits (Volume Vendu)" styleClass="section-title"/>
                    <TableView fx:id="tableTopProduits" VBox.vgrow="ALWAYS" prefHeight="260" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colTopNom" text="Produit" prefWidth="300"/>
                            <TableColumn fx:id="colTopQte" text="Unités" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" styleClass="card, chart-box">
                    <Label text="Top 5 Produits (Parts de Volume)" styleClass="section-title"/>
                    <PieChart fx:id="pieTopProduits" prefHeight="260" animated="true"/>
                </VBox>
            </HBox>

            <!-- PERTES -->
            <VBox styleClass="card, chart-box">
                <Label text="Pertes &amp; Ajustements par Motif" styleClass="section-title"/>
                <BarChart fx:id="barPertes" prefHeight="240" animated="true" styleClass="premium-chart">
                    <xAxis><CategoryAxis label="Motif"/></xAxis>
                    <yAxis><NumberAxis label="Unités retirées"/></yAxis>
                </BarChart>
            </VBox>
        </VBox>

    </VBox>
</ScrollPane>
