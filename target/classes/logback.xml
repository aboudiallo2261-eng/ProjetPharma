<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Définition des dossiers de log -->
    <!-- Le dossier d'exécution servira de racine pour les logs -->
    <property name="LOG_DIR" value="logs" />

    <!-- 1. Console Appender : Principalement pour le développement (IntelliJ/Eclipse) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 2. RollingFileAppender : Le cœur de l'auditabilité pour le client final -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- Fichier actif qui reçoit les logs du moment -->
        <file>${LOG_DIR}/vet-pharmacy.log</file>

        <!-- Configuration de la rotation (Rolling Policy) basée sur la date et la taille -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Nom des archives. ex: vet-pharmacy-2026-04-18.0.log -->
            <fileNamePattern>${LOG_DIR}/archive/vet-pharmacy-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- Limite à 10 MB par fichier avant d'en créer un nouveau le même jour (.1.log, .2.log) -->
            <maxFileSize>10MB</maxFileSize>
            <!-- Conservation des archives pendant 30 jours maximum (auto-nettoyage) -->
            <maxHistory>30</maxHistory>
            <!-- Taille maximale cumulée du dossier des logs (1 Go) avant suppression forcée des vieux -->
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 3. AsyncAppender : Enveloppe le FileAppender pour éviter les blocages de l'interface JavaFX -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <!-- Ne perd jamais les logs (0), même si la file d'attente est remplie (dégradation temporelle acceptée au profit de la donnée) -->
        <discardingThreshold>0</discardingThreshold>
        <!-- Taille de la file d'attente asynchrone -->
        <queueSize>512</queueSize>
        <!-- Lie l'appender asynchrone au RollingFileAppender -->
        <appender-ref ref="FILE" />
    </appender>

    <!-- Niveau de log global de l'application -->
    <root level="INFO">
        <!-- En production, on privilégie l'écriture ASYNC sur disque -->
        <appender-ref ref="ASYNC_FILE" />
        <!-- On garde la console active pour le développeur -->
        <appender-ref ref="CONSOLE" />
    </root>

    <!-- On rend Hibernate silencieux sur les infos triviales pour ne pas polluer les fichiers,
         on ne garde que ses WARN ou ERROR pour détecter de vraies failles SQL -->
    <logger name="org.hibernate" level="WARN" />

</configuration>
